# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git (it contains secrets)

tenancy_ocid     = "ocid1.tenancy.oc1..aaaaaaaaxxxxxxxx"
user_ocid        = "ocid1.user.oc1..aaaaaaaaxxxxxxxx"
fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
private_key_path = "~/.oci/oci_api_key.pem"
compartment_ocid = "ocid1.compartment.oc1..aaaaaaaaxxxxxxxx"
region           = "ap-mumbai-1"

ssh_public_key = "ssh-rsa AAAA... your-key"

# Always Free tier defaults (change if needed)
instance_shape     = "VM.Standard.A1.Flex"
instance_ocpus     = 1
instance_memory_gb = 6

# App config
app_name     = "skribbl"
git_repo_url = "https://github.com/imrankhan8107/skribbl-app.git"
git_branch   = "feature/redis-scaling"
