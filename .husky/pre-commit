#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Detect which files are staged
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

HAS_FRONTEND=$(echo "$STAGED_FILES" | grep -c "^frontend/" || true)
HAS_BACKEND=$(echo "$STAGED_FILES" | grep -c "^backend/" || true)

# ============================================================
# Frontend checks (only if frontend files changed)
# ============================================================
if [ "$HAS_FRONTEND" -gt 0 ]; then
  echo "📦 Frontend changes detected — running checks..."
  cd frontend

  # Get only staged frontend files for targeted checks
  STAGED_TS=$(echo "$STAGED_FILES" | grep "^frontend/.*\.\(ts\|tsx\)$" | sed 's|^frontend/||' || true)
  STAGED_CSS=$(echo "$STAGED_FILES" | grep "^frontend/.*\.css$" | sed 's|^frontend/||' || true)
  STAGED_FORMAT="$STAGED_TS $STAGED_CSS"

  # Prettier — only on changed files
  if [ -n "$(echo "$STAGED_FORMAT" | tr -d ' ')" ]; then
    echo "  → Prettier (staged files only)..."
    echo "$STAGED_FORMAT" | xargs npx prettier --check 2>/dev/null || {
      echo "❌ Prettier failed. Run: cd frontend && npm run format"
      exit 1
    }
  fi

  # TypeScript — always check full project (types are interconnected)
  echo "  → TypeScript compile check..."
  npx tsc --noEmit || { echo "❌ TypeScript errors found."; exit 1; }

  # Build
  echo "  → Build..."
  npm run build || { echo "❌ Frontend build failed."; exit 1; }

  # Tests — run related tests only using vitest's changed file detection
  echo "  → Tests (related to changes)..."
  if [ -n "$STAGED_TS" ]; then
    npx vitest run --reporter=verbose --changed HEAD~1 2>/dev/null || npx vitest run || {
      echo "❌ Frontend tests failed."
      exit 1
    }
  else
    echo "  → Skipping tests (no .ts/.tsx changes)"
  fi

  cd ..
  echo "✅ Frontend checks passed!"
else
  echo "⏭️  No frontend changes — skipping frontend checks"
fi

# ============================================================
# Backend checks (only if backend files changed)
# ============================================================
if [ "$HAS_BACKEND" -gt 0 ]; then
  echo "🐍 Backend changes detected — running checks..."

  # Get changed backend test files and source files
  STAGED_PY=$(echo "$STAGED_FILES" | grep "^backend/.*\.py$" || true)
  STAGED_TESTS=$(echo "$STAGED_PY" | grep "tests/" || true)
  STAGED_SRC=$(echo "$STAGED_PY" | grep -v "tests/" || true)

  # If source files changed, run all tests (changes could affect anything)
  # If only test files changed, run just those tests
  if [ -n "$STAGED_SRC" ]; then
    echo "  → Source files changed — running full test suite..."
    python -m pytest backend/tests/ -q --tb=short || {
      echo "❌ Backend tests failed."
      exit 1
    }
  elif [ -n "$STAGED_TESTS" ]; then
    echo "  → Only test files changed — running changed tests..."
    echo "$STAGED_TESTS" | xargs python -m pytest -q --tb=short || {
      echo "❌ Backend tests failed."
      exit 1
    }
  fi

  echo "✅ Backend checks passed!"
else
  echo "⏭️  No backend changes — skipping backend checks"
fi

echo ""
echo "🎉 All pre-commit checks passed!"
